name: Statistical Validation

on:
  push:
    branches:
      - master
      - main
      - "0.[0-9]+.[0-9]+"
    paths:
      - "scirs2-stats/**"
      - "scirs2-linalg/**"
      - "scirs2-special/**"
      - "scirs2-python/**"
      - "scripts/validate_distributions.py"
      - "scripts/validate_linalg.py"
      - "scripts/reference_values/**"
      - ".github/workflows/statistical-validation.yml"
  pull_request:
    branches:
      - master
      - main
      - "0.[0-9]+.[0-9]+"
    paths:
      - "scirs2-stats/**"
      - "scirs2-linalg/**"
      - "scirs2-special/**"
      - "scirs2-python/**"
      - "scripts/validate_distributions.py"
      - "scripts/validate_linalg.py"
      - "scripts/reference_values/**"
  workflow_dispatch:
    inputs:
      mode:
        description: "Validation mode (standalone or live)"
        required: false
        default: "standalone"
        type: choice
        options:
          - standalone
          - live

env:
  CARGO_TERM_COLOR: always
  RUST_BACKTRACE: 1

jobs:
  # ---------------------------------------------------------------------------
  # Standalone validation — runs without a Rust build.
  # Compares SciPy's current output against the pre-computed JSON baseline.
  # ---------------------------------------------------------------------------
  standalone-validation:
    name: Standalone Distribution/Linalg Validation (Python ${{ matrix.python }})
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        python: ["3.10", "3.11", "3.12"]

    steps:
      - uses: actions/checkout@v4

      - name: Set up Python ${{ matrix.python }}
        uses: actions/setup-python@v5
        with:
          python-version: ${{ matrix.python }}

      - name: Install Python dependencies
        run: |
          python -m pip install --upgrade pip
          pip install numpy scipy

      - name: Verify validation scripts are present
        run: |
          test -f scripts/validate_distributions.py || { echo "ERROR: validate_distributions.py missing"; exit 1; }
          test -f scripts/validate_linalg.py        || { echo "ERROR: validate_linalg.py missing"; exit 1; }
          test -f scripts/reference_values/distributions.json || { echo "ERROR: distributions.json missing"; exit 1; }
          echo "All validation scripts present."

      - name: Run distribution validation (standalone)
        run: |
          python scripts/validate_distributions.py \
            --verbose \
            --report /tmp/dist_report_standalone_py${{ matrix.python }}.json

      - name: Run linalg validation (standalone)
        run: |
          python scripts/validate_linalg.py \
            --verbose \
            --report /tmp/linalg_report_standalone_py${{ matrix.python }}.json

      - name: Upload standalone validation reports
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: validation-standalone-py${{ matrix.python }}
          path: |
            /tmp/dist_report_standalone_py${{ matrix.python }}.json
            /tmp/linalg_report_standalone_py${{ matrix.python }}.json
          retention-days: 30
          if-no-files-found: warn

  # ---------------------------------------------------------------------------
  # Reference baseline drift check
  # ---------------------------------------------------------------------------
  baseline-verification:
    name: Reference Baseline Drift Check
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - name: Set up Python 3.12
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Install Python dependencies
        run: pip install numpy scipy

      - name: Verify baseline values against current SciPy
        run: |
          python - <<'PYEOF'
          """
          Spot-check key values from the JSON baseline against live SciPy calls.
          Uses a tighter tolerance (1e-9) than the main scripts to catch upstream
          SciPy changes early.
          """
          import json, sys, math
          from pathlib import Path
          from scipy import stats as sp

          baseline = json.loads(
              Path("scripts/reference_values/distributions.json").read_text()
          )

          DRIFT_TOL = 1e-9
          failures = []

          def check(name, expected, actual, label):
              if expected is None:
                  return
              if abs(expected) < 1e-300:
                  err = abs(actual - expected)
                  ok = err < DRIFT_TOL
              else:
                  err = abs(actual - expected) / abs(expected)
                  ok = err < DRIFT_TOL
              if not ok:
                  failures.append(
                      f"{name}/{label}: expected={expected:.12g}, "
                      f"scipy={actual:.12g}, drift={err:.3e}"
                  )

          dists = baseline["distributions"]

          # Normal(0,1)
          d = sp.norm(0, 1)
          for pt in dists["normal"]["pdf_points"]:
              check("normal", pt["pdf"], d.pdf(pt["x"]), f"pdf@{pt['x']}")
          for pt in dists["normal"]["cdf_points"]:
              check("normal", pt["cdf"], d.cdf(pt["x"]), f"cdf@{pt['x']}")

          # Gamma(shape=2, scale=1)
          g = sp.gamma(2, scale=1)
          for pt in dists["gamma"]["pdf_points"]:
              check("gamma", pt["pdf"], g.pdf(pt["x"]), f"pdf@{pt['x']}")
          for pt in dists["gamma"]["cdf_points"]:
              check("gamma", pt["cdf"], g.cdf(pt["x"]), f"cdf@{pt['x']}")

          # Gamma(shape=3, scale=0.5) — parameterization regression guard
          g2 = sp.gamma(3, scale=0.5)
          for pt in dists["gamma_shape3_rate2"]["pdf_points"]:
              check("gamma_shape3_rate2", pt["pdf"], g2.pdf(pt["x"]), f"pdf@{pt['x']}")

          # Poisson(mu=3)
          p = sp.poisson(3)
          for pt in dists["poisson"]["pmf_points"]:
              check("poisson", pt["pmf"], p.pmf(pt["k"]), f"pmf@{pt['k']}")

          # Beta(2,5)
          b = sp.beta(2, 5)
          for pt in dists["beta"]["pdf_points"][:4]:
              check("beta", pt["pdf"], b.pdf(pt["x"]), f"pdf@{pt['x']}")

          # t(df=10)
          t = sp.t(10)
          for pt in dists["t_distribution"]["pdf_points"]:
              check("t_dist", pt["pdf"], t.pdf(pt["x"]), f"pdf@{pt['x']}")

          if failures:
              print("BASELINE DRIFT DETECTED:")
              for f in failures:
                  print(f"  {f}")
              print(f"\nTotal: {len(failures)} value(s) drifted beyond {DRIFT_TOL}")
              sys.exit(1)

          print(f"Baseline verification passed — no drift detected (tol={DRIFT_TOL})")
          PYEOF

  # ---------------------------------------------------------------------------
  # Live validation with maturin (optional, continue-on-error)
  # ---------------------------------------------------------------------------
  live-validation:
    name: Live Validation (maturin build + scipy cross-check)
    runs-on: ubuntu-latest
    continue-on-error: true

    steps:
      - uses: actions/checkout@v4

      - name: Set up Python 3.11
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install Rust toolchain
        uses: dtolnay/rust-toolchain@stable

      - uses: Swatinem/rust-cache@v2
        with:
          prefix-key: "v1-statval-ubuntu-stable"

      - name: Install Python dependencies
        run: pip install "maturin>=1.4,<2" numpy scipy

      - name: Build scirs2-python wheel (release mode)
        run: |
          cd scirs2-python
          maturin build --out dist --release 2>&1 | tail -100
        continue-on-error: true

      - name: Install wheel (if built)
        shell: bash
        run: |
          if ls scirs2-python/dist/*.whl 1>/dev/null 2>&1; then
            pip install scirs2-python/dist/*.whl
            echo "WHEEL_INSTALLED=true" >> "$GITHUB_ENV"
          else
            echo "Wheel not found; live validation will run scipy-vs-scipy scaffold"
            echo "WHEEL_INSTALLED=false" >> "$GITHUB_ENV"
          fi

      - name: Run distribution live validation
        run: |
          python scripts/validate_distributions.py \
            --live \
            --verbose \
            --report /tmp/dist_report_live.json
        continue-on-error: true

      - name: Run linalg live validation
        run: |
          python scripts/validate_linalg.py \
            --live \
            --verbose \
            --report /tmp/linalg_report_live.json
        continue-on-error: true

      - name: Upload live validation reports
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: validation-live
          path: |
            /tmp/dist_report_live.json
            /tmp/linalg_report_live.json
          retention-days: 30
          if-no-files-found: warn

  # ---------------------------------------------------------------------------
  # Gamma parameterization regression guard
  # ---------------------------------------------------------------------------
  gamma-parameterization-guard:
    name: Gamma Parameterization Regression Guard
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - name: Set up Python 3.11
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install Python dependencies
        run: pip install numpy scipy

      - name: Check Gamma rate/scale parameterization
        run: |
          python - <<'PYEOF'
          """
          Explicit guard against Gamma parameterization bugs.

          Bug class: confusing rate=lambda vs scale=1/lambda.
          - Gamma(shape=2, rate=2)  has mean=1, var=0.5  (scale=0.5)
          - Gamma(shape=2, scale=2) has mean=4, var=8
          """
          import sys
          from scipy import stats as sp

          TOL = 1e-9
          failures = []

          def near(a, b, label):
              if abs(a - b) / max(abs(b), 1e-300) > TOL:
                  failures.append(f"{label}: got {a:.10g}, expected {b:.10g}")

          # scale parameterization (scipy native)
          # Gamma(shape=2, scale=1): mean=2, var=2, pdf(1.0)=0.3678794...
          g_s1 = sp.gamma(a=2, scale=1.0)
          near(g_s1.mean(), 2.0,                   "gamma(a=2,scale=1).mean")
          near(g_s1.var(),  2.0,                   "gamma(a=2,scale=1).var")
          near(g_s1.pdf(1.0), 0.36787944117144233, "gamma(a=2,scale=1).pdf(1.0)")
          near(g_s1.cdf(2.0), 0.5939941502901619,  "gamma(a=2,scale=1).cdf(2.0)")

          # Gamma(shape=3, scale=0.5) = Gamma(shape=3, rate=2)
          # mean = shape * scale = 1.5, var = 0.75
          g_r2 = sp.gamma(a=3, scale=0.5)
          near(g_r2.mean(), 1.5,  "gamma(a=3,rate=2).mean")
          near(g_r2.var(),  0.75, "gamma(a=3,rate=2).var")
          near(g_r2.pdf(1.0), 0.5413411329464508, "gamma(a=3,rate=2).pdf(1.0)")

          # Verify scale=2 != scale=0.5 (rate/scale confusion guard)
          g_wrong = sp.gamma(a=3, scale=2.0)
          if abs(g_wrong.mean() - g_r2.mean()) < 0.01:
              failures.append(
                  "GUARD: gamma(a=3,scale=2).mean == gamma(a=3,scale=0.5).mean — "
                  "parameterization test is broken"
              )
          if abs(g_wrong.pdf(1.0) - g_r2.pdf(1.0)) < 0.01:
              failures.append(
                  "GUARD: gamma(a=3,scale=2).pdf(1) == gamma(a=3,scale=0.5).pdf(1) — "
                  "parameterization test is broken"
              )

          # Chi-squared / Gamma relationship: chi2(df=4) == gamma(a=2, scale=2)
          chi4  = sp.chi2(df=4)
          gamma_equiv = sp.gamma(a=2, scale=2)
          near(chi4.mean(), gamma_equiv.mean(), "chi2(4) mean vs gamma(2,2)")
          near(chi4.var(),  gamma_equiv.var(),  "chi2(4) var  vs gamma(2,2)")
          near(chi4.pdf(2.0), gamma_equiv.pdf(2.0), "chi2(4).pdf(2) vs gamma(2,2).pdf(2)")

          if failures:
              print("GAMMA PARAMETERIZATION GUARD FAILED:")
              for f in failures:
                  print(f"  FAIL: {f}")
              sys.exit(1)

          print("Gamma parameterization guard: ALL CHECKS PASSED")
          PYEOF

  # ---------------------------------------------------------------------------
  # Summary
  # ---------------------------------------------------------------------------
  statistical-validation-summary:
    name: Statistical Validation Summary
    runs-on: ubuntu-latest
    needs:
      - standalone-validation
      - baseline-verification
      - live-validation
      - gamma-parameterization-guard
    if: always()

    steps:
      - name: Check critical validation jobs
        shell: bash
        run: |
          echo "=== Statistical Validation Results ==="
          echo "standalone-validation:        ${{ needs.standalone-validation.result }}"
          echo "baseline-verification:        ${{ needs.baseline-verification.result }}"
          echo "live-validation:              ${{ needs.live-validation.result }} (optional)"
          echo "gamma-parameterization-guard: ${{ needs.gamma-parameterization-guard.result }}"
          echo ""

          FAILED=0

          if [[ "${{ needs.standalone-validation.result }}" != "success" ]]; then
            echo "FAILED: standalone-validation"
            echo "  Distribution PDF/CDF values or linalg factorizations do not match"
            echo "  the pre-computed SciPy reference baseline."
            FAILED=$((FAILED + 1))
          fi

          if [[ "${{ needs.baseline-verification.result }}" != "success" ]]; then
            echo "FAILED: baseline-verification"
            echo "  The stored reference values in distributions.json have drifted"
            echo "  from the current SciPy output beyond the allowed tolerance (1e-9)."
            echo "  Regenerate: python scripts/generate_baseline.py"
            FAILED=$((FAILED + 1))
          fi

          if [[ "${{ needs.gamma-parameterization-guard.result }}" != "success" ]]; then
            echo "FAILED: gamma-parameterization-guard"
            echo "  Gamma rate/scale parameterization regression detected."
            FAILED=$((FAILED + 1))
          fi

          if [[ "${{ needs.live-validation.result }}" == "failure" ]]; then
            echo "WARNING: live-validation failed (optional; non-blocking)"
          fi

          if [[ "$FAILED" -gt 0 ]]; then
            echo ""
            echo "ERROR: $FAILED mandatory statistical validation job(s) failed."
            exit 1
          fi

          echo "All mandatory statistical validation checks PASSED."
